# Copy this to .env and fill in your values

# From Supabase → Project Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# A long, random secret string for signing JWT tokens (make one up, keep it secret)
JWT_SECRET=your_super_secret_key_here_change_this

# The URL of your deployed frontend on Vercel (no trailing slash)
CLIENT_URL=https://your-app.vercel.app

# The URL of this backend server (used for profile picture URLs)
SERVER_URL=https://your-backend.railway.app

# Port (Railway sets this automatically, don't change)
PORT=3001
